<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SOCIAL_MEDIA_APP_FINAL_PROJECT.ViewModel"
             x:Class="SOCIAL_MEDIA_APP_FINAL_PROJECT.profile"
             BackgroundColor="#000000"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:ProfileViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── TOP NAV BAR ── -->
        <Grid Grid.Row="0"
              BackgroundColor="#0D0D0D"
              Padding="16,48,16,14"
              ColumnDefinitions="Auto,*,Auto">

            <!-- Back Button -->
            <Border Grid.Column="0"
                    BackgroundColor="#1A1A1A"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="10,8"
                    Margin="0,0,12,0">
                <Label Text="←" FontSize="18" TextColor="White">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>

            <Label Grid.Column="1" Text="My Profile"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="White" VerticalOptions="Center"/>

            <!-- Save / Edit toggle -->
            <Border Grid.Column="2"
                    BackgroundColor="{Binding IsEditing, Converter={StaticResource BoolToEditBgConverter}}"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="14,8">
                <Label Text="{Binding EditButtonText}"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="{Binding IsEditing, Converter={StaticResource BoolToEditTextConverter}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleEditCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- ── SCROLLABLE BODY ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- Hero / Cover Banner -->
                <Grid HeightRequest="140">
                    <BoxView Color="#0D2B1A" VerticalOptions="Fill"/>
                    <!-- Subtle grid pattern overlay -->
                    <BoxView Color="#06C167" Opacity="0.04" VerticalOptions="Fill"/>
                    <Label Text="✦  ✦  ✦  ✦  ✦  ✦  ✦  ✦  ✦  ✦  ✦  ✦"
                           TextColor="#06C167" Opacity="0.12" FontSize="18"
                           VerticalOptions="Center" HorizontalOptions="Center"/>
                </Grid>

                <!-- Avatar overlapping the banner -->
                <Grid Margin="0,-56,0,0" HorizontalOptions="Center" ZIndex="10">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="0">

                        <!-- Avatar Circle -->
                        <Grid WidthRequest="112" HeightRequest="112" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 56"
            Stroke="#06C167" StrokeThickness="3"
            WidthRequest="112" HeightRequest="112"
            BackgroundColor="#1A1A1A">
                                <Grid>
                                    <!-- Fallback emoji when no image -->
                                    <Label Text="👤" FontSize="52"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   IsVisible="{Binding HasNoAvatarImage}"/>

                                    <!-- Remote URL avatar (from MockAPI) -->
                                    <!-- Remote URL avatar (from MockAPI) -->
                                    <Image Aspect="AspectFill"
                                   Source="{Binding AvatarImageSource}"
                                   IsVisible="{Binding HasAvatarImage}"/>

                                    <!-- Locally picked image (overrides remote) -->
                                    <Image Source="{Binding PickedAvatarSource}"
                   Aspect="AspectFill"
                   IsVisible="{Binding HasPickedAvatar}"/>
                                </Grid>
                            </Border>

                            <!-- Camera badge (edit mode only) -->
                            <Border IsVisible="{Binding IsEditing}"
                                    BackgroundColor="#06C167"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="Transparent"
                                    WidthRequest="32" HeightRequest="32"
                                    HorizontalOptions="End" VerticalOptions="End"
                                    Margin="0,0,4,4">
                                <Label Text="📷" FontSize="14"
                                       HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PickAvatarCommand}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </Grid>

                        <!-- Name + Username under avatar -->
                        <Label Text="{Binding DisplayName}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center"
                               Margin="0,12,0,2"/>
                        <Label Text="{Binding DisplayEmail}"
                               FontSize="13" TextColor="#06C167"
                               HorizontalOptions="Center" Margin="0,0,0,4"/>

                        <!-- Stats row -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="32" Margin="0,12,0,0">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="48" FontSize="18" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"/>
                                <Label Text="Posts" FontSize="12" TextColor="#555555"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <BoxView WidthRequest="1" HeightRequest="36" Color="#2A2A2A" VerticalOptions="Center"/>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="1.2K" FontSize="18" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"/>
                                <Label Text="Followers" FontSize="12" TextColor="#555555"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <BoxView WidthRequest="1" HeightRequest="36" Color="#2A2A2A" VerticalOptions="Center"/>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="324" FontSize="18" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"/>
                                <Label Text="Following" FontSize="12" TextColor="#555555"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- ── EDIT FORM ── -->
                <VerticalStackLayout Padding="24,28,24,0" Spacing="20">

                    <!-- Section Label -->
                    <HorizontalStackLayout Spacing="8">
                        <BoxView WidthRequest="3" HeightRequest="18" Color="#06C167"
                                 VerticalOptions="Center" CornerRadius="2"/>
                        <Label Text="Account Details" FontSize="13" FontAttributes="Bold"
                               TextColor="#A0A0A0" VerticalOptions="Center" CharacterSpacing="1.5"/>
                    </HorizontalStackLayout>

                    <!-- Username Field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="USERNAME" FontSize="11" TextColor="#555555"
                               FontAttributes="Bold" CharacterSpacing="1.2"/>
                        <Border BackgroundColor="#0D0D0D"
                                StrokeShape="RoundRectangle 12"
                                Stroke="{Binding IsEditing, Converter={StaticResource BoolToFieldStrokeConverter}}"
                                Padding="16,0">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="👤" FontSize="16"
                                       VerticalOptions="Center" Margin="0,0,10,0"/>
                                <Entry Grid.Column="1"
                                       Text="{Binding Username}"
                                       Placeholder="Your username"
                                       PlaceholderColor="#333333"
                                       TextColor="White"
                                       BackgroundColor="Transparent"
                                       HeightRequest="52"
                                       IsReadOnly="{Binding IsNotEditing}"
                                       FontSize="15"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email Field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="EMAIL" FontSize="11" TextColor="#555555"
                               FontAttributes="Bold" CharacterSpacing="1.2"/>
                        <Border BackgroundColor="#0D0D0D"
                                StrokeShape="RoundRectangle 12"
                                Stroke="{Binding IsEditing, Converter={StaticResource BoolToFieldStrokeConverter}}"
                                Padding="16,0">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="✉️" FontSize="16"
                                       VerticalOptions="Center" Margin="0,0,10,0"/>
                                <Entry Grid.Column="1"
                                       Text="{Binding Email}"
                                       Placeholder="Your email"
                                       PlaceholderColor="#333333"
                                       TextColor="White"
                                       Keyboard="Email"
                                       BackgroundColor="Transparent"
                                       HeightRequest="52"
                                       IsReadOnly="{Binding IsNotEditing}"
                                       FontSize="15"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password Field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PASSWORD" FontSize="11" TextColor="#555555"
                               FontAttributes="Bold" CharacterSpacing="1.2"/>
                        <Border BackgroundColor="#0D0D0D"
                                StrokeShape="RoundRectangle 12"
                                Stroke="{Binding IsEditing, Converter={StaticResource BoolToFieldStrokeConverter}}"
                                Padding="16,0">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" Text="🔒" FontSize="16"
                                       VerticalOptions="Center" Margin="0,0,10,0"/>
                                <Entry Grid.Column="1"
                                       Text="{Binding Password}"
                                       Placeholder="New password"
                                       PlaceholderColor="#333333"
                                       TextColor="White"
                                       IsPassword="{Binding PasswordHidden}"
                                       BackgroundColor="Transparent"
                                       HeightRequest="52"
                                       IsReadOnly="{Binding IsNotEditing}"
                                       FontSize="15"/>
                                <Label Grid.Column="2"
                                       Text="{Binding PasswordToggleIcon}"
                                       FontSize="16"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding IsEditing}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TogglePasswordCommand}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                        <Label Text="Leave blank to keep current password"
                               FontSize="11" TextColor="#444444"
                               IsVisible="{Binding IsEditing}"
                               Margin="4,0,0,0"/>
                    </VerticalStackLayout>

                    <!-- Avatar URL Field (edit mode only) -->
                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditing}">
                        <Label Text="AVATAR URL  (optional)" FontSize="11" TextColor="#555555"
                               FontAttributes="Bold" CharacterSpacing="1.2"/>
                        <Border StrokeShape="RoundRectangle 56"
            Stroke="#06C167" StrokeThickness="3"
            WidthRequest="112" HeightRequest="112"
            BackgroundColor="#1A1A1A">
                            <Grid>
                                <!-- Fallback emoji when no image -->
                                <Label Text="👤" FontSize="52"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   IsVisible="{Binding HasNoAvatarImage}"/>

                                <Image Aspect="AspectFill"
     Source="{Binding AvatarImageSource}"
     IsVisible="{Binding HasAvatarImage}"/>

                                <!-- Locally picked image (overrides remote) -->
                                <Image Source="{Binding PickedAvatarSource}"
                   Aspect="AspectFill"
                   IsVisible="{Binding HasPickedAvatar}"/>
                            </Grid>
                        </Border>

                        <!-- Or pick from gallery -->
                        <Button Text="📷  Pick from Gallery"
                                BackgroundColor="#1A1A1A"
                                TextColor="#06C167"
                                FontAttributes="Bold"
                                FontSize="14"
                                HeightRequest="48"
                                CornerRadius="12"
                                Command="{Binding PickAvatarCommand}"/>
                    </VerticalStackLayout>

                    <!-- Error / Success Message -->
                    <Label Text="{Binding StatusMessage}"
                           TextColor="{Binding StatusColor}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding HasStatusMessage}"/>

                    <!-- Save Changes Button (edit mode) -->
                    <Button Text="Save Changes"
                            BackgroundColor="#06C167"
                            TextColor="Black"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="54"
                            CornerRadius="27"
                            IsVisible="{Binding IsEditing}"
                            Command="{Binding SaveProfileCommand}"
                            IsEnabled="{Binding IsNotBusy}"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#06C167"
                                       HorizontalOptions="Center"/>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#1A1A1A" Margin="0,8"/>

                    <!-- Section Label -->
                    <HorizontalStackLayout Spacing="8">
                        <BoxView WidthRequest="3" HeightRequest="18" Color="#FF4444"
                                 VerticalOptions="Center" CornerRadius="2"/>
                        <Label Text="Danger Zone" FontSize="13" FontAttributes="Bold"
                               TextColor="#A0A0A0" VerticalOptions="Center" CharacterSpacing="1.5"/>
                    </HorizontalStackLayout>

                    <!-- Logout Button -->
                    <Border BackgroundColor="#1A0000"
                            StrokeShape="RoundRectangle 16"
                            Stroke="#FF4444"
                            Padding="20,16"
                            Margin="0,0,0,40">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="🚪" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Log Out" FontSize="16" FontAttributes="Bold"
                                       TextColor="#FF4444"/>
                                <Label Text="You'll need to log in again" FontSize="12"
                                       TextColor="#553333"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="→" FontSize="18"
                                   TextColor="#FF4444" VerticalOptions="Center">
                            </Label>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── BOTTOM NAV BAR ── -->
        <Border Grid.Row="2"
                BackgroundColor="#0D0D0D"
                StrokeShape="RoundRectangle 0"
                Stroke="#1A1A1A"
                Padding="0,10,0,28">
            <Grid ColumnDefinitions="*,*,*,*,*">
                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <Label Text="🏠" FontSize="22" HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoHomeCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView HeightRequest="3" WidthRequest="20" Color="Transparent"
                             HorizontalOptions="Center" CornerRadius="2"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <Label Text="👥" FontSize="22" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="3" WidthRequest="20" Color="Transparent"
                             HorizontalOptions="Center" CornerRadius="2"/>
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        BackgroundColor="#06C167"
                        StrokeShape="RoundRectangle 28"
                        Stroke="Transparent"
                        WidthRequest="52" HeightRequest="52"
                        HorizontalOptions="Center"
                        Margin="0,-16,0,0">
                    <Label Text="+" FontSize="28" FontAttributes="Bold"
                           TextColor="Black"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                    <Label Text="💬" FontSize="22" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="3" WidthRequest="20" Color="Transparent"
                             HorizontalOptions="Center" CornerRadius="2"/>
                </VerticalStackLayout>

                <!-- Profile (active) -->
                <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="Center">
                    <Border StrokeShape="RoundRectangle 14"
                            Stroke="#06C167" StrokeThickness="2"
                            WidthRequest="28" HeightRequest="28"
                            BackgroundColor="#1A1A1A"
                            HorizontalOptions="Center">
                        <Label Text="👤" FontSize="14"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView HeightRequest="3" WidthRequest="20" Color="#06C167"
                             HorizontalOptions="Center" CornerRadius="2"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
