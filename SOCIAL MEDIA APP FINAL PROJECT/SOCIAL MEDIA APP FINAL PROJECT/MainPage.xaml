<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SOCIAL_MEDIA_APP_FINAL_PROJECT.ViewModel"
             x:Class="SOCIAL_MEDIA_APP_FINAL_PROJECT.MainPage"
             BackgroundColor="#000000">

    <ContentPage.BindingContext>
        <vm:AuthViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="24,48,24,32" Spacing="0">

            <!-- Logo -->
            <HorizontalStackLayout HorizontalOptions="Start" Margin="0,0,0,32">
                <Label Text="Social" FontSize="26" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="Center"/>
                <Border BackgroundColor="#06C167" Padding="6,3"
                        Margin="6,0,0,0" VerticalOptions="Center"
                        StrokeShape="RoundRectangle 4" Stroke="Transparent">
                    <Label Text="App" FontSize="14" FontAttributes="Bold" TextColor="Black"/>
                </Border>
            </HorizontalStackLayout>

            <!-- Heading -->
            <Label Text="Get Started now" FontSize="30" FontAttributes="Bold"
                   TextColor="White" Margin="0,0,0,8"/>
            <Label Text="Sign up for a new account or log in to your existing one to browse and connect."
                   FontSize="14" TextColor="#A0A0A0" Margin="0,0,0,28"/>

            <!-- Toggle: Login / Register -->
            <Border BackgroundColor="#1A1A1A" StrokeShape="RoundRectangle 30"
                    Stroke="Transparent" Padding="4" Margin="0,0,0,28">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                    <!-- Login Tab -->
                    <Border Grid.Column="0"
                            BackgroundColor="{Binding IsLoginMode, Converter={StaticResource BoolToLoginBgConverter}}"
                            StrokeShape="RoundRectangle 26" Stroke="Transparent" Padding="0,10">
                        <Label Text="Login"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"
                               FontSize="15"
                               TextColor="{Binding IsLoginMode, Converter={StaticResource BoolToLoginTextConverter}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SwitchToLoginCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <!-- Register Tab -->
                    <Border Grid.Column="1"
                            BackgroundColor="{Binding IsLoginMode, Converter={StaticResource BoolToRegisterBgConverter}}"
                            StrokeShape="RoundRectangle 26" Stroke="Transparent" Padding="0,10">
                        <Label Text="Register"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"
                               FontSize="15"
                               TextColor="{Binding IsLoginMode, Converter={StaticResource BoolToRegisterTextConverter}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SwitchToRegisterCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>
            </Border>

            <!-- Register-only: Username Field -->
            <VerticalStackLayout IsVisible="{Binding IsRegisterMode}" Spacing="0" Margin="0,0,0,16">
                <Label Text="Username" TextColor="#A0A0A0" FontSize="13" Margin="0,0,0,6"/>
                <Border BackgroundColor="#1A1A1A" StrokeShape="RoundRectangle 12"
                        Stroke="#2A2A2A" Padding="14,0">
                    <Entry Placeholder="Enter your username"
                           PlaceholderColor="#555555"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           HeightRequest="50"
                           Text="{Binding Username}"/>
                </Border>
            </VerticalStackLayout>

            <!-- Email Field -->
            <Label Text="Email" TextColor="#A0A0A0" FontSize="13" Margin="0,0,0,6"/>
            <Border BackgroundColor="#1A1A1A" StrokeShape="RoundRectangle 12"
                    Stroke="#2A2A2A" Padding="14,0" Margin="0,0,0,16">
                <Entry Placeholder="Enter your email"
                       PlaceholderColor="#555555"
                       TextColor="White"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       HeightRequest="50"
                       Text="{Binding Email}"/>
            </Border>

            <!-- Password Field -->
            <Label Text="Password" TextColor="#A0A0A0" FontSize="13" Margin="0,0,0,6"/>
            <Border BackgroundColor="#1A1A1A" StrokeShape="RoundRectangle 12"
                    Stroke="#2A2A2A" Padding="14,0" Margin="0,0,0,8">
                <Entry Placeholder="Enter your password"
                       PlaceholderColor="#555555"
                       TextColor="White"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       HeightRequest="50"
                       Text="{Binding Password}"/>
            </Border>

            <!-- Remember Me + Forgot Password (Login only) -->
            <Grid ColumnDefinitions="Auto,*,Auto" IsVisible="{Binding IsLoginMode}" Margin="0,0,0,28">
                <CheckBox Grid.Column="0" Color="#06C167" IsChecked="{Binding RememberMe}" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="Remember me" TextColor="#A0A0A0"
                       FontSize="13" VerticalOptions="Center" Margin="4,0,0,0"/>
                <Label Grid.Column="2" Text="Forgot Password?" TextColor="#06C167"
                       FontSize="13" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Confirm Password (Register only) -->
            <VerticalStackLayout IsVisible="{Binding IsRegisterMode}" Spacing="0" Margin="0,0,0,28">
                <Label Text="Confirm Password" TextColor="#A0A0A0" FontSize="13" Margin="0,0,0,6"/>
                <Border BackgroundColor="#1A1A1A" StrokeShape="RoundRectangle 12"
                        Stroke="#2A2A2A" Padding="14,0">
                    <Entry Placeholder="Confirm your password"
                           PlaceholderColor="#555555"
                           TextColor="White"
                           IsPassword="True"
                           BackgroundColor="Transparent"
                           HeightRequest="50"
                           Text="{Binding ConfirmPassword}"/>
                </Border>
            </VerticalStackLayout>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#FF4444"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding HasError}"
                   Margin="0,0,0,12"/>

            <!-- Primary Action Button -->
            <Button Text="{Binding ActionButtonText}"
                    BackgroundColor="#06C167"
                    TextColor="Black"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="54"
                    CornerRadius="27"
                    Command="{Binding AuthCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,0,0,20"/>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#06C167"
                               HorizontalOptions="Center"
                               Margin="0,0,0,12"/>

            <!-- Divider -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,0,0,20">
                <BoxView HeightRequest="1" WidthRequest="100" Color="#2A2A2A" VerticalOptions="Center"/>
                <Label Text="Or Sign In With" TextColor="#555555" FontSize="13"/>
                <BoxView HeightRequest="1" WidthRequest="100" Color="#2A2A2A" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Social Sign-In Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,28">
                <Border Grid.Column="0" BackgroundColor="#1A1A1A"
                        StrokeShape="RoundRectangle 12" Stroke="#2A2A2A" Padding="0,14">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="🍎" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="Apple" TextColor="White" FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AppleSignInCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="1" BackgroundColor="#1A1A1A"
                        StrokeShape="RoundRectangle 12" Stroke="#2A2A2A" Padding="0,14">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="G" TextColor="#EA4335" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="Google" TextColor="White" FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoogleSignInCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- Bottom Switch Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="{Binding BottomLinkText}" TextColor="#A0A0A0" FontSize="14"/>
                <Label Text="{Binding BottomLinkAction}" TextColor="#06C167"
                       FontSize="14" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleModeCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
