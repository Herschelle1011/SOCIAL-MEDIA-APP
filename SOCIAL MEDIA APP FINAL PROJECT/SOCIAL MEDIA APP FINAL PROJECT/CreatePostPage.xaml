<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SOCIAL_MEDIA_APP_FINAL_PROJECT.ViewModel"
             x:Class="SOCIAL_MEDIA_APP_FINAL_PROJECT.CreatePostPage"
             BackgroundColor="#000000"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:CreatePostViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── TOP BAR ── -->
        <Grid Grid.Row="0"
              BackgroundColor="#0D0D0D"
              Padding="16,48,16,14"
              ColumnDefinitions="Auto,*,Auto">

            <!-- Cancel -->
            <Border Grid.Column="0"
                    BackgroundColor="#1A1A1A"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="14,8">
                <Label Text="Cancel" FontSize="14" TextColor="#A0A0A0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>

            <Label Grid.Column="1" Text="Create Post"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <!-- Post Button -->
            <Border Grid.Column="2"
                    BackgroundColor="#06C167"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="18,8">
                <Label Text="Post" FontSize="14" FontAttributes="Bold" TextColor="Black">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SubmitPostCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- ── BODY ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- Author Info -->
                <HorizontalStackLayout Padding="16,16,16,12" Spacing="12">
                    <Border StrokeShape="RoundRectangle 24"
                            Stroke="#06C167" StrokeThickness="2"
                            WidthRequest="48" HeightRequest="48"
                            BackgroundColor="#1A1A1A">
                        <Image Aspect="AspectFill">
                            <Image.Source>
                                <UriImageSource Uri="{Binding AvatarUrl}"
                                               CacheValidity="1:00:00:00"/>
                            </Image.Source>
                        </Image>
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding AuthorName}"
                               FontSize="15" FontAttributes="Bold" TextColor="White"/>
                        <Border BackgroundColor="#1A1A1A" Padding="10,4"
                                StrokeShape="RoundRectangle 12" Stroke="#2A2A2A">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="🌍" FontSize="12"/>
                                <Label Text="Public" FontSize="12" TextColor="#A0A0A0"
                                       VerticalOptions="Center"/>
                                <Label Text="▾" FontSize="10" TextColor="#555555"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Text Input -->
                <Editor Placeholder="What's on your mind?"
                        PlaceholderColor="#333333"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="16"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="160"
                        Margin="16,0,16,0"
                        Text="{Binding PostContent}"/>

                <!-- Character count -->
                <Label Text="{Binding CharacterCount, StringFormat='{0}/500'}"
                       TextColor="#333333" FontSize="12"
                       HorizontalOptions="End" Margin="0,4,20,12"/>

                <!-- Divider -->
                <BoxView HeightRequest="1" Color="#1A1A1A" Margin="16,0,16,16"/>

                <!-- Image Preview (if picked) -->
                <Border IsVisible="{Binding HasImage}"
                        Margin="16,0,16,16"
                        StrokeShape="RoundRectangle 16"
                        Stroke="#2A2A2A" BackgroundColor="#1A1A1A">
                    <Grid>
                        <Image Source="{Binding PickedImageSource}"
                               Aspect="AspectFill"
                               HeightRequest="200"/>
                        <!-- Remove image button -->
                        <Border BackgroundColor="#000000"
                                StrokeShape="RoundRectangle 16"
                                Stroke="Transparent"
                                WidthRequest="30" HeightRequest="30"
                                HorizontalOptions="End" VerticalOptions="Start"
                                Margin="0,8,8,0">
                            <Label Text="✕" FontSize="14" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding RemoveImageCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                    </Grid>
                </Border>

                <!-- Add to Post section -->
                <Border Margin="16,0,16,16"
                        BackgroundColor="#0D0D0D"
                        StrokeShape="RoundRectangle 16"
                        Stroke="#2A2A2A" Padding="16,12">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Add to your post" FontSize="13"
                               TextColor="#A0A0A0" FontAttributes="Bold"
                               Margin="0,0,0,12"/>

                        <!-- Photo -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,10"
                              BackgroundColor="Transparent">
                            <Border Grid.Column="0"
                                    BackgroundColor="#0D2B1A"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="📷" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="Photo / Video"
                                   TextColor="White" FontSize="15"
                                   VerticalOptions="Center" Margin="12,0,0,0"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="#555555" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickImageCommand}"/>
                            </Grid.GestureRecognizers>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1A1A1A" Margin="0,4"/>

                        <!-- Feeling -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,10">
                            <Border Grid.Column="0"
                                    BackgroundColor="#1A0D2B"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="😊" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="Feeling / Activity"
                                   TextColor="White" FontSize="15"
                                   VerticalOptions="Center" Margin="12,0,0,0"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="#555555" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1A1A1A" Margin="0,4"/>

                        <!-- Location -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,10">
                            <Border Grid.Column="0"
                                    BackgroundColor="#1A1A0D"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36" HeightRequest="36">
                                <Label Text="📍" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="Check In"
                                   TextColor="White" FontSize="15"
                                   VerticalOptions="Center" Margin="12,0,0,0"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="#555555" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Error Message -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#FF4444" FontSize="13"
                       HorizontalOptions="Center"
                       IsVisible="{Binding HasError}"
                       Margin="16,0,16,12"/>

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#06C167"
                                   HorizontalOptions="Center"
                                   Margin="0,0,0,16"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── BOTTOM POST BUTTON (alternative big button) ── -->
        <Border Grid.Row="2"
                BackgroundColor="#0D0D0D"
                Stroke="#1A1A1A"
                Padding="16,12,16,32">
            <Button Text="Share Post"
                    BackgroundColor="#06C167"
                    TextColor="Black"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="52"
                    CornerRadius="26"
                    Command="{Binding SubmitPostCommand}"
                    IsEnabled="{Binding CanPost}"/>
        </Border>

    </Grid>
</ContentPage>
