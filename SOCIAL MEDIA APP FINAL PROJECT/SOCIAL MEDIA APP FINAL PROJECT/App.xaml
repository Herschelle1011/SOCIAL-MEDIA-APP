<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SOCIAL_MEDIA_APP_FINAL_PROJECT"
             xmlns:converters="clr-namespace:SOCIAL_MEDIA_APP_FINAL_PROJECT.Converters"
             x:Class="SOCIAL_MEDIA_APP_FINAL_PROJECT.App">
    <Application.Resources>
   
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToLoginBgConverter x:Key="BoolToLoginBgConverter"/>
            <converters:BoolToLoginTextConverter x:Key="BoolToLoginTextConverter"/>
            <converters:BoolToRegisterBgConverter x:Key="BoolToRegisterBgConverter"/>
            <converters:BoolToRegisterTextConverter x:Key="BoolToRegisterTextConverter"/>

            <converters:BoolToEditBgConverter      x:Key="BoolToEditBgConverter" />
            <converters:BoolToEditTextConverter    x:Key="BoolToEditTextConverter" />
            <converters:BoolToFieldStrokeConverter x:Key="BoolToFieldStrokeConverter" />
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
