<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SOCIAL_MEDIA_APP_FINAL_PROJECT.ViewModel"
             x:Class="SOCIAL_MEDIA_APP_FINAL_PROJECT.HomePage"
             BackgroundColor="#000000"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:HomeViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── TOP NAV BAR ── -->
        <Grid Grid.Row="0"
              BackgroundColor="#0D0D0D"
              Padding="16,48,16,12"
              ColumnDefinitions="*,Auto,Auto,Auto">

            <!-- Logo -->
            <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                <Label Text="Social" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                <Border BackgroundColor="#06C167" Padding="5,2"
                        StrokeShape="RoundRectangle 4" Stroke="Transparent">
                    <Label Text="App" FontSize="11" FontAttributes="Bold" TextColor="Black"/>
                </Border>
            </HorizontalStackLayout>

            <!-- Search Icon -->
            <Border Grid.Column="1"
                    BackgroundColor="#1A1A1A"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="10"
                    Margin="0,0,8,0">
                <Label Text="🔍" FontSize="16"/>
            </Border>

            <!-- Notification Icon -->
            <Border Grid.Column="2"
                    BackgroundColor="#1A1A1A"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="10"
                    Margin="0,0,8,0">
                <Grid>
                    <Label Text="🔔" FontSize="16"/>
                    <Border BackgroundColor="#06C167"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            WidthRequest="16" HeightRequest="16"
                            HorizontalOptions="End" VerticalOptions="Start"
                            Margin="-2,-2,0,0">
                        <Label Text="3" FontSize="9" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Avatar → tap to go to profile -->
            <Border Grid.Column="3"
                    StrokeShape="RoundRectangle 20"
                    Stroke="#06C167" StrokeThickness="1.5"
                    WidthRequest="38" HeightRequest="38"
                    BackgroundColor="#1A1A1A">
                <Image Aspect="AspectFill">
                    <Image.Source>
                        <UriImageSource Uri="{Binding AvatarUrl}"
                                        CacheValidity="1:00:00:00"/>
                    </Image.Source>
                </Image>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToProfileCommand}"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <!-- ── MAIN FEED ── -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}"
                     RefreshColor="#06C167">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- Stories Row -->
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                                Padding="12,16,12,16">
                        <HorizontalStackLayout Spacing="12">

                            <!-- Your Story -->
                            <VerticalStackLayout Spacing="6" WidthRequest="72">
                                <Border StrokeShape="RoundRectangle 36"
                                        Stroke="#06C167" StrokeThickness="2"
                                        WidthRequest="72" HeightRequest="72"
                                        BackgroundColor="#1A1A1A">
                                    <Grid>
                                        <!-- Current user avatar in story -->
                                        <Image Aspect="AspectFill">
                                            <Image.Source>
                                                <UriImageSource Uri="{Binding AvatarUrl}"
                                                                CacheValidity="1:00:00:00"/>
                                            </Image.Source>
                                        </Image>
                                        <Border BackgroundColor="#06C167"
                                                StrokeShape="RoundRectangle 12"
                                                Stroke="#000000" StrokeThickness="2"
                                                WidthRequest="22" HeightRequest="22"
                                                HorizontalOptions="End" VerticalOptions="End">
                                            <Label Text="+" FontSize="13" FontAttributes="Bold"
                                                   TextColor="Black"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Label Text="Your Story" FontSize="11" TextColor="#A0A0A0"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Static friend stories -->
                            <VerticalStackLayout Spacing="6" WidthRequest="72">
                                <Border StrokeShape="RoundRectangle 36"
                                        Stroke="#06C167" StrokeThickness="2"
                                        WidthRequest="72" HeightRequest="72"
                                        BackgroundColor="#1A1A1A">
                                    <Label Text="👤" FontSize="30"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Alex" FontSize="11" TextColor="#CCCCCC"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6" WidthRequest="72">
                                <Border StrokeShape="RoundRectangle 36"
                                        Stroke="#2A2A2A" StrokeThickness="2"
                                        WidthRequest="72" HeightRequest="72"
                                        BackgroundColor="#1A1A1A">
                                    <Label Text="👩" FontSize="30"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Maria" FontSize="11" TextColor="#CCCCCC"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6" WidthRequest="72">
                                <Border StrokeShape="RoundRectangle 36"
                                        Stroke="#06C167" StrokeThickness="2"
                                        WidthRequest="72" HeightRequest="72"
                                        BackgroundColor="#1A1A1A">
                                    <Label Text="🧑" FontSize="30"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Jake" FontSize="11" TextColor="#CCCCCC"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6" WidthRequest="72">
                                <Border StrokeShape="RoundRectangle 36"
                                        Stroke="#2A2A2A" StrokeThickness="2"
                                        WidthRequest="72" HeightRequest="72"
                                        BackgroundColor="#1A1A1A">
                                    <Label Text="👩‍🦰" FontSize="30"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="Sara" FontSize="11" TextColor="#CCCCCC"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#1A1A1A" Margin="0,0,0,8"/>

                    <!-- Create Post Bar -->
                    <Border BackgroundColor="#0D0D0D" Margin="12,0,12,16"
                            StrokeShape="RoundRectangle 16" Stroke="#2A2A2A" Padding="14,12">
                        <HorizontalStackLayout Spacing="12">
                            <Border StrokeShape="RoundRectangle 20"
                                    Stroke="#06C167" StrokeThickness="1.5"
                                    WidthRequest="40" HeightRequest="40"
                                    BackgroundColor="#1A1A1A">
                                <Image Aspect="AspectFill">
                                    <Image.Source>
                                        <UriImageSource Uri="{Binding AvatarUrl}"
                                                        CacheValidity="1:00:00:00"/>
                                    </Image.Source>
                                </Image>
                            </Border>
                            <Border BackgroundColor="#1A1A1A"
                                    StrokeShape="RoundRectangle 20"
                                    Stroke="#2A2A2A"
                                    HorizontalOptions="FillAndExpand"
                                    Padding="16,10">
                                <Label Text="What's on your mind?" TextColor="#555555" FontSize="14">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding CreatePostCommand}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Post action icons -->
                    <HorizontalStackLayout Margin="16,0,16,16" Spacing="0">
                        <HorizontalStackLayout HorizontalOptions="FillAndExpand" Spacing="6">
                            <Label Text="📷" FontSize="16"/>
                            <Label Text="Photo" TextColor="#A0A0A0" FontSize="13" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout HorizontalOptions="FillAndExpand" Spacing="6">
                            <Label Text="🎥" FontSize="16"/>
                            <Label Text="Video" TextColor="#A0A0A0" FontSize="13" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout HorizontalOptions="FillAndExpand" Spacing="6">
                            <Label Text="😊" FontSize="16"/>
                            <Label Text="Feeling" TextColor="#A0A0A0" FontSize="13" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="8" Color="#0D0D0D"/>

                    <!-- ── POSTS FROM MOCKAPI ── -->
                    <CollectionView ItemsSource="{Binding Posts}"
                                    Margin="0,8,0,0"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PostModel">
                                <VerticalStackLayout BackgroundColor="#000000" Margin="0,0,0,0">

                                    <!-- Post Header -->
                                    <Grid Padding="16,14,16,10" ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 22"
                                                Stroke="#06C167" StrokeThickness="2"
                                                WidthRequest="44" HeightRequest="44"
                                                BackgroundColor="#1A1A1A" Margin="0,0,12,0">
                                            <Image Aspect="AspectFill">
                                                <Image.Source>
                                                    <UriImageSource Uri="{Binding AuthorAvatar}"
                                                                    CacheValidity="1:00:00:00"/>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding AuthorName}"
                                                   FontSize="15" FontAttributes="Bold" TextColor="White"/>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding TimeAgo}"
                                                       FontSize="12" TextColor="#555555"/>
                                                <Label Text="🌍" FontSize="12"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="···" FontSize="20"
                                               TextColor="#A0A0A0" VerticalOptions="Center"/>
                                    </Grid>

                                    <!-- Post Text -->
                                    <Label Padding="16,0,16,12"
                                           Text="{Binding Content}"
                                           TextColor="#DDDDDD" FontSize="14" LineHeight="1.5"/>

                                    <!-- Post Image (only shown if valid URL) -->
                                    <Image IsVisible="{Binding HasImage}"
                                           HeightRequest="220"
                                           Aspect="AspectFill"
                                           Margin="0,0,0,0">
                                        <Image.Source>
                                            <UriImageSource Uri="{Binding ImageUrl}"
                                                            CacheValidity="1:00:00:00"/>
                                        </Image.Source>
                                    </Image>

                                    <!-- Reaction counts -->
                                    <HorizontalStackLayout Padding="16,10,16,6" Spacing="6">
                                        <Label Text="👍❤️😮" FontSize="13"/>
                                        <Label Text="{Binding LikesCount, StringFormat='{0} reactions'}"
                                               TextColor="#555555" FontSize="13"
                                               HorizontalOptions="FillAndExpand"/>
                                        <Label Text="{Binding CommentsCount, StringFormat='{0} comments'}"
                                               TextColor="#555555" FontSize="13"/>
                                    </HorizontalStackLayout>

                                    <!-- Divider -->
                                    <BoxView HeightRequest="1" Color="#1A1A1A" Margin="16,0"/>

                                    <!-- Action Buttons -->
                                    <Grid Padding="8,4" ColumnDefinitions="*,*,*">
                                        <Button Grid.Column="0" Text="👍  Like"
                                                BackgroundColor="Transparent"
                                                TextColor="#A0A0A0"
                                                FontSize="14" HeightRequest="44"/>
                                        <Button Grid.Column="1" Text="💬  Comment"
                                                BackgroundColor="Transparent"
                                                TextColor="#A0A0A0"
                                                FontSize="14" HeightRequest="44"/>
                                        <Button Grid.Column="2" Text="↗️  Share"
                                                BackgroundColor="Transparent"
                                                TextColor="#A0A0A0"
                                                FontSize="14" HeightRequest="44"/>
                                    </Grid>

                                    <!-- Post separator -->
                                    <BoxView HeightRequest="8" Color="#0D0D0D"/>

                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <!-- Empty state -->
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="12" Padding="40">
                                <Label Text="📭" FontSize="48" HorizontalOptions="Center"/>
                                <Label Text="No posts yet" TextColor="#555555"
                                       FontSize="16" HorizontalOptions="Center"/>
                                <Label Text="Pull down to refresh" TextColor="#333333"
                                       FontSize="13" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <!-- Bottom padding for nav bar -->
                    <BoxView HeightRequest="80" Color="Transparent"/>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ── BOTTOM NAV BAR ── -->
        <Border Grid.Row="2"
                BackgroundColor="#0D0D0D"
                StrokeShape="RoundRectangle 0"
                Stroke="#1A1A1A"
                Padding="0,10,0,28">
            <Grid ColumnDefinitions="*,*,*,*,*">

                <!-- Home (active) -->
                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <Label Text="🏠" FontSize="22" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="3" WidthRequest="20" Color="#06C167"
                             HorizontalOptions="Center" CornerRadius="2"/>
                </VerticalStackLayout>

                <!-- Friends -->
                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <Label Text="👥" FontSize="22" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="3" WidthRequest="20" Color="Transparent"
                             HorizontalOptions="Center" CornerRadius="2"/>
                </VerticalStackLayout>

                <!-- Create Post (center) -->
                <Border Grid.Column="2"
                        BackgroundColor="#06C167"
                        StrokeShape="RoundRectangle 28"
                        Stroke="Transparent"
                        WidthRequest="52" HeightRequest="52"
                        HorizontalOptions="Center"
                        Margin="0,-16,0,0">
                    <Label Text="+" FontSize="28" FontAttributes="Bold"
                           TextColor="Black"
                           HorizontalOptions="Center" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CreatePostCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

                <!-- Messages -->
                <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                    <Grid>
                        <Label Text="💬" FontSize="22" HorizontalOptions="Center"/>
                        <Border BackgroundColor="#06C167"
                                StrokeShape="RoundRectangle 8"
                                Stroke="Transparent"
                                WidthRequest="16" HeightRequest="16"
                                HorizontalOptions="End" VerticalOptions="Start"
                                Margin="10,-4,0,0">
                            <Label Text="5" FontSize="9" FontAttributes="Bold"
                                   TextColor="Black" HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                    <BoxView HeightRequest="3" WidthRequest="20" Color="Transparent"
                             HorizontalOptions="Center" CornerRadius="2"/>
                </VerticalStackLayout>

                <!-- Profile (tap → ProfilePage) -->
                <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToProfileCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border StrokeShape="RoundRectangle 14"
                            Stroke="#06C167" StrokeThickness="1.5"
                            WidthRequest="32" HeightRequest="32"
                            BackgroundColor="#1A1A1A"
                            HorizontalOptions="Center">
                        <Image Aspect="AspectFill">
                            <Image.Source>
                                <UriImageSource Uri="{Binding AvatarUrl}"
                                                CacheValidity="1:00:00:00"/>
                            </Image.Source>
                        </Image>
                    </Border>
                    <BoxView HeightRequest="3" WidthRequest="20" Color="Transparent"
                             HorizontalOptions="Center" CornerRadius="2"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
